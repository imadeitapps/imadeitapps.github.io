---
/**
 * StarRating
 *
 * Renders up to 5 stars filled proportionally to the rating value.
 * Uses SVG paths so no icon font is required.
 *
 * Props:
 *   rating  – 0–5 number (will be rounded to 1 dp for display)
 *   count   – total number of ratings (optional, shown as "(n)" label)
 *   size    – star size in px (default 10)
 */
interface Props {
  rating: number;
  count?: number;
  size?: number;
}

const { rating, count, size = 10 } = Astro.props;

// Clamp to [0, 5] and round display value to 1 decimal place
const value    = Math.min(5, Math.max(0, rating ?? 0));
const display  = value.toFixed(1);
const filled   = Math.round(value); // round to nearest whole star

function formatCount(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000)     return `${(n / 1_000).toFixed(0)}K`;
  return String(n);
}
---

<span class="star-rating" aria-label={`${display} out of 5 stars${count ? `, ${count} ratings` : ''}`} role="img">
  <span class="stars" aria-hidden="true">
    {Array.from({ length: 5 }, (_, i) => {
      const isFilled = i < filled;
      return (
        <svg
          width={size}
          height={size}
          viewBox="0 0 24 24"
          fill={isFilled ? 'var(--c-accent)' : 'var(--c-border-m)'}
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
      );
    })}
  </span>

  <span class="star-val">{display}</span>

  {count !== undefined && count > 0 && (
    <span class="star-val" style="opacity:.65">({formatCount(count)})</span>
  )}
</span>
